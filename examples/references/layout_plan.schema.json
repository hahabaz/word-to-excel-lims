{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/word-to-excel-lims/layout_plan.schema.json",
  "title": "Word to Excel LIMS Layout Plan",
  "type": "object",
  "required": ["schema_version", "source", "case_library", "workbook"],
  "properties": {
    "schema_version": {"type": "string"},
    "source": {
      "type": "object",
      "properties": {
        "docx_path": {"type": "string"},
        "estimated_word_pages": {"type": ["integer", "null"]},
        "summary": {"type": "string"},
        "complexity": {"type": "string"}
      },
      "additionalProperties": true
    },
    "case_library": {
      "type": "object",
      "properties": {
        "status": {"enum": ["empty", "used", "available_not_used"]},
        "selected_case": {"type": ["string", "null"]},
        "notes": {"type": "string"}
      },
      "additionalProperties": true
    },
    "workbook": {
      "type": "object",
      "required": ["sheets"],
      "properties": {
        "creator": {"type": "string"},
        "sheets": {
          "type": "array",
          "items": {"$ref": "#/$defs/sheet"}
        }
      }
    }
  },
  "$defs": {
    "sheet": {
      "type": "object",
      "required": ["name", "page_setup", "base_grid", "sections"],
      "properties": {
        "name": {"type": "string"},
        "page_setup": {
          "type": "object",
          "properties": {
            "paper_size": {"type": "string", "default": "A4"},
            "orientation": {"enum": ["portrait", "landscape"]},
            "horizontal_centered": {"type": "boolean"},
            "fit_to_width": {"type": "integer"},
            "fit_to_height": {"type": ["integer", "null"]},
            "margins": {"type": "object"},
            "print_area": {"type": ["string", "null"]}
          },
          "additionalProperties": true
        },
        "base_grid": {
          "type": "object",
          "required": ["base_columns", "equal_column_width"],
          "properties": {
            "base_columns": {"type": "integer", "minimum": 8, "maximum": 96},
            "equal_column_width": {"type": "number"},
            "start_column": {"type": "integer", "default": 1},
            "default_row_height": {"type": "number", "default": 18}
          }
        },
        "sections": {
          "type": "array",
          "items": {"$ref": "#/$defs/section"}
        },
        "qa": {"type": "object", "additionalProperties": true}
      }
    },
    "section": {
      "type": "object",
      "required": ["type", "rows"],
      "properties": {
        "type": {"type": "string"},
        "title": {"type": "string"},
        "top_spacing": {"type": "integer", "default": 0},
        "rows": {
          "type": "array",
          "items": {"$ref": "#/$defs/row"}
        }
      }
    },
    "row": {
      "type": "object",
      "properties": {
        "height": {"type": "number"},
        "cells": {
          "type": "array",
          "items": {"$ref": "#/$defs/cell"}
        }
      }
    },
    "cell": {
      "type": "object",
      "required": ["start_col", "colspan", "text"],
      "properties": {
        "start_col": {"type": "integer", "minimum": 1},
        "colspan": {"type": "integer", "minimum": 1},
        "text": {"type": "string"},
        "rowspan": {"type": "integer", "minimum": 1, "default": 1},
        "style": {"type": "string"},
        "align": {"enum": ["left", "center", "right"]},
        "valign": {"enum": ["top", "center", "bottom"]},
        "wrap": {"type": "boolean"},
        "border": {"enum": ["none", "bottom", "box", "grid"]},
        "font_bold": {"type": "boolean"},
        "font_size": {"type": "number"}
      },
      "additionalProperties": true
    }
  }
}
